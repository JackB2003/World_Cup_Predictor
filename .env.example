# Server
NODE_ENV=development
PORT=3000

# PocketBase
POCKETBASE_URL=http://127.0.0.1:8090
POCKETBASE_ADMIN_EMAIL=
POCKETBASE_ADMIN_PASSWORD=

# API-Football (server-side only — never expose to browser)
# Production: set API_FOOTBALL_MOCK=false and provide API_FOOTBALL_KEY
API_FOOTBALL_KEY=
API_FOOTBALL_MOCK=true
ELO_RATINGS_MOCK=true
WORLD_CUP_LEAGUE_ID=1
WORLD_CUP_SEASON=2026

# Elo ratings from https://eloratings.net/ (no API key; set ELO_RATINGS_MOCK=false in production)

# OpenAI (server-side only)
OPENAI_API_KEY=

# Admin refresh token — required in production (Bearer auth for POST /api/refresh)
ADMIN_REFRESH_TOKEN=
